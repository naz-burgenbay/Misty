@* Standalone online/offline indicator. *@

@code {
    [Parameter] public bool Online { get; set; }
    [Parameter] public int SizePx { get; set; } = 8;
}

<span class="dot @(Online ? "online" : "offline")"
      style="width:@(SizePx)px;height:@(SizePx)px"
      aria-label="@(Online ? "Online" : "Offline")"></span>
