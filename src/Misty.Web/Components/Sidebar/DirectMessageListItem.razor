@implements IDisposable
@inject IUserDirectory Users

@code {
    [Parameter, EditorRequired] public DirectConversationDto Conversation { get; set; } = default!;
    [Parameter] public bool Selected { get; set; }
    [Parameter] public string Href { get; set; } = "#";

    private UserSummary _other = default!;
    private bool _subscribed;

    protected override void OnParametersSet()
    {
        _other = Users.Get(Conversation.OtherUserId);
        _ = Users.EnsureAsync(Conversation.OtherUserId);
        if (!_subscribed)
        {
            Users.Updated += OnUserUpdated;
            _subscribed = true;
        }
    }

    private void OnUserUpdated(Guid userId)
    {
        if (userId != Conversation.OtherUserId) return;
        _other = Users.Get(userId);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (_subscribed) Users.Updated -= OnUserUpdated;
    }
}

<a class="row @(Selected ? "selected" : "")" href="@Href">
    <Avatar Name="@_other.DisplayName"
            Size="Avatar.AvatarSize.Medium" />
    <div class="text">
        <div class="line">
            <span class="name">@_other.DisplayName</span>
        </div>
    </div>
</a>
